@page
@model Web.Pages.Vehiculos.DetalleModel
@{
}

<div class="container mt-4">

    <h2 class="mb-4">Detalle del Vehículo</h2>

    <div class="card mb-3 shadow-sm">
        <div class="row g-0">

            <div class="col-md-4 text-center">
                <img src="~/assets/img/car.png" class="img-fluid p-4" alt="Vehículo">
            </div>

            <div class="col-md-8">
                <div class="card-body">

                    <h5 class="card-title">
                        @Html.DisplayFor(modelo => modelo.vehiculo.Marca)
                        @Html.DisplayFor(modelo => modelo.vehiculo.Modelo)
                    </h5>

                    <p class="card-text mb-1">
                        <strong>@Html.DisplayNameFor(modelo => modelo.vehiculo.Placa):</strong>
                        @Html.DisplayFor(modelo => modelo.vehiculo.Placa)
                    </p>

                    <p class="card-text mb-1">
                        <strong>@Html.DisplayNameFor(modelo => modelo.vehiculo.Anio):</strong>
                        @Html.DisplayFor(modelo => modelo.vehiculo.Anio)
                    </p>

                    <p class="card-text mb-2">
                        <strong>@Html.DisplayNameFor(modelo => modelo.vehiculo.Precio):</strong>
                        @Html.DisplayFor(modelo => modelo.vehiculo.Precio)
                    </p>

                    <p class="card-text">
                        <small class="text-muted">
                            @Html.DisplayFor(modelo => modelo.vehiculo.CorreoPropietario) /
                            @Html.DisplayFor(modelo => modelo.vehiculo.TelefonoPropietario)
                        </small>
                    </p>

                </div>
            </div>

        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="./Index">Regresar</a>
        <a class="btn btn-warning" asp-page="./Editar" asp-route-id="@Model.vehiculo.Id">Editar</a>
    </div>

</div>