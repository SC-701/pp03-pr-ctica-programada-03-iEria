@page
@model Web.Pages.Vehiculos.IndexModel
@{
}

<div class="container mt-4">

    <h2 class="mb-4">Listado de Vehículos</h2>

    <div class="mb-3">
        <a class="btn btn-success" asp-page="./Agregar">
            <i class="bi bi-plus-square"></i> Agregar Vehículo
        </a>
    </div>

    <div class="row">

        @if (Model.vehiculos != null)
        {
            @foreach (var vehiculo in Model.vehiculos)
            {
                <div class="col-md-4 mb-3">

                    <div class="card">

                        <div class="card-body">

                            <h5 class="card-title">
                                <i class="bi bi-car-front-fill"></i>
                                @Html.DisplayFor(modelo => vehiculo.Marca)
                                @Html.DisplayFor(modelo => vehiculo.Modelo)
                            </h5>

                            <h6 class="text-muted">
                                Año: @Html.DisplayFor(modelo => vehiculo.Anio)
                            </h6>

                            <p class="card-text">
                                Placa: @Html.DisplayFor(modelo => vehiculo.Placa)
                            </p>

                            <a class="btn btn-primary btn-sm"
                               asp-page="./Detalle"
                               asp-route-id="@vehiculo.Id">
                                <i class="bi bi-info-square"></i> Detalle
                            </a>

                            <a class="btn btn-warning btn-sm"
                               asp-page="./Editar"
                               asp-route-id="@vehiculo.Id">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>

                            <a class="btn btn-danger btn-sm"
                               asp-page="./Eliminar"
                               asp-route-id="@vehiculo.Id">
                                <i class="bi bi-trash3-fill"></i> Eliminar
                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="alert alert-warning">
                No hay vehículos disponibles.
            </div>
        }

    </div>

</div>